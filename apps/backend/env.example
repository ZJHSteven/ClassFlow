# ClassFlow Rust 后端环境变量示例
#
# 使用方式：
# 1. 复制到服务器上的 `/etc/classflow/backend.env`
# 2. 按实际机器路径、密钥、R2 参数修改
# 3. 由 systemd 的 `EnvironmentFile=` 读取

CLASSFLOW_BIND_ADDR=0.0.0.0:8787
CLASSFLOW_DB_URL=sqlite:///opt/classflow/data/classflow.db?mode=rwc
CLASSFLOW_BEARER_TOKEN=replace-with-a-long-random-token
CLASSFLOW_DEFAULT_SEMESTER=2025-2026-2

CLASSFLOW_TEMP_ROOT=/opt/classflow/tmp
CLASSFLOW_LOCAL_ARTIFACT_ROOT=/opt/classflow/data/artifacts

CLASSFLOW_TASK_WORKER_COUNT=4
CLASSFLOW_DOWNLOAD_CONCURRENCY=4
CLASSFLOW_UPLOAD_CONCURRENCY=2
CLASSFLOW_TRANSCRIBE_CONCURRENCY=2
CLASSFLOW_R2_CONCURRENCY=4
CLASSFLOW_TMP_CLEANUP_HOURS=168
CLASSFLOW_TASK_EVENT_RETENTION_DAYS=30
CLASSFLOW_TASK_EVENT_RETENTION_ROWS_PER_TASK=200

# 下载链路（aria2c）
CLASSFLOW_ARIA2_BIN=aria2c
CLASSFLOW_DOWNLOAD_RETRY_ATTEMPTS=3
CLASSFLOW_DOWNLOAD_RETRY_WAIT_SECS=3.0
CLASSFLOW_DOWNLOAD_CONNECT_TIMEOUT_SECS=15.0
CLASSFLOW_DOWNLOAD_TIMEOUT_SECS=60.0
CLASSFLOW_DOWNLOAD_SPLIT=6
CLASSFLOW_DOWNLOAD_CONNECTIONS_PER_SERVER=6
# 设为 0 表示默认不因为“速度慢”主动失败；只有你明确填正数时才启用低速退出。
CLASSFLOW_DOWNLOAD_LOWEST_SPEED_LIMIT_BYTES=0

# local / r2 / worker
CLASSFLOW_ARTIFACT_STORE_MODE=worker
CLASSFLOW_ARTIFACT_PROXY_BASE_URL=https://classflow-web.example.com/
CLASSFLOW_ARTIFACT_PROXY_TOKEN=replace-with-worker-artifact-token
# 如果 `CLASSFLOW_ARTIFACT_PROXY_BASE_URL` 指向的 Worker 域名被 Cloudflare Access 保护，
# 后端写 R2 产物时也必须带 Service Token；否则请求会先被 Access 重定向到登录页，根本到不了 Worker 私有接口。
# 也可以改用通用变量名 `CF_ACCESS_CLIENT_ID` / `CF_ACCESS_CLIENT_SECRET`，后端会自动兼容读取。
CLASSFLOW_ARTIFACT_PROXY_ACCESS_CLIENT_ID=replace-with-access-client-id
CLASSFLOW_ARTIFACT_PROXY_ACCESS_CLIENT_SECRET=replace-with-access-client-secret

# 阿里百炼 / DashScope
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
# 录音文件转写模型。当前默认值改为 `fun-asr-mtl`。
# 如果你后续想切回 `fun-asr`、或切到带日期版本号的固定模型，也只改这一行即可。
# 注意：本值会同时用于“上传临时 oss:// 文件时申请凭证”和“真正提交转写任务”；
# 两边模型名必须完全一致，否则上传成功后仍可能在转写阶段失败。
CLASSFLOW_DASHSCOPE_MODEL=fun-asr-mtl
CLASSFLOW_DASHSCOPE_SUBMIT_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription
CLASSFLOW_DASHSCOPE_TASK_URL_TEMPLATE=https://dashscope.aliyuncs.com/api/v1/tasks/{task_id}
CLASSFLOW_DASHSCOPE_UPLOAD_POLICY_URL=https://dashscope.aliyuncs.com/api/v1/uploads
CLASSFLOW_DASHSCOPE_REQUEST_TIMEOUT_SECS=60.0
CLASSFLOW_DASHSCOPE_REQUEST_RETRY_ATTEMPTS=3
CLASSFLOW_DASHSCOPE_REQUEST_RETRY_WAIT_SECS=3.0
CLASSFLOW_UPLOAD_RETRY_ATTEMPTS=3
CLASSFLOW_UPLOAD_RETRY_WAIT_SECS=3.0
CLASSFLOW_UPLOAD_TIMEOUT_SECS=900.0
CLASSFLOW_DASHSCOPE_POLL_INTERVAL_SECS=1.0
CLASSFLOW_DASHSCOPE_POLL_TIMEOUT_SECS=900.0

# Cloudflare R2（仅在 CLASSFLOW_ARTIFACT_STORE_MODE=r2 时由后端直连使用）
CLASSFLOW_R2_BUCKET=replace-with-r2-bucket
CLASSFLOW_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLASSFLOW_R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
CLASSFLOW_R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
CLASSFLOW_R2_REGION=auto
